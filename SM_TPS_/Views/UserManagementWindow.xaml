<Window x:Class="SM_TPS_.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SM_TPS_.ViewModels"
        Title="User Management"
        Height="550"
        Width="1000"
        Background="#F4F7FC"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:UserManagementViewModel/>
    </Window.DataContext>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Card -->

        <Border Grid.Column="0"
                Background="White"
                CornerRadius="15"
                Padding="20">

            <StackPanel>

                <TextBlock Text="👤 Add New User"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Username"
                           FontWeight="SemiBold"/>

                <TextBox Text="{Binding Username}"
                         Height="40"
                         Margin="0,5,0,15"
                         FontSize="14"/>

                <TextBlock Text="Password"
                           FontWeight="SemiBold"/>

                <TextBox Text="{Binding Password}"
                         Height="40"
                         Margin="0,5,0,15"
                         FontSize="14"/>

                <TextBlock Text="Role"
                           FontWeight="SemiBold"/>

                <ComboBox SelectedItem="{Binding Role}"
                          Height="40"
                          Margin="0,5,0,25">

                    <ComboBoxItem Content="Admin"/>
                    <ComboBoxItem Content="Cashier"/>

                </ComboBox>

                <Button Content="➕ Add User"
                        Height="45"
                        FontSize="15"
                        FontWeight="Bold"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding AddUserCommand}"/>
                
                <Button Content="🗑 Delete User"
                        Height="40"
                        FontWeight="Bold"
                        Background="Red" 
                        Foreground="White"
                        Margin="0,10,0,0"
                        Command="{Binding DeleteUserCommand}"/>
                
                <Button Content="🔑 Reset Password"
                        Height="40"
                         FontWeight="Bold"
                         Background="YellowGreen"    
                         Foreground="White"
                        Margin="0,10,0,0"
                        Command="{Binding ResetPasswordCommand}"/>  


            </StackPanel>

        </Border>

        <!-- Right Card -->

        <Border Grid.Column="1"
                Margin="20,0,0,0"
                Background="White"
                CornerRadius="15"
                Padding="15">


            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="👥 System Users"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          RowHeight="35">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Username"
                                            Binding="{Binding Username}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Password"
                                            Binding="{Binding Password}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Role"
                                            Binding="{Binding Role}"
                                            Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>
</Window>
